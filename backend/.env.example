# Database (Cloud SQL via Unix socket on Cloud Run, TCP locally)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/wellness_db

# Google Cloud
GCP_PROJECT_ID=your-project-id
GCP_LOCATION=us-central1
GCS_BUCKET_NAME=your-bucket-name
# Set this to a service account key file path for local dev;
# on Cloud Run, use Workload Identity instead
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Clerk
CLERK_SECRET_KEY=sk_test_...
CLERK_JWT_ISSUER=https://your-clerk-instance.clerk.accounts.dev
# Webhook signing secret from the Clerk Dashboard → Webhooks endpoint
# Leave empty (default) to skip signature verification in local dev
# Use `ngrok http 8000` then set the tunnel URL in Clerk Dashboard to test locally
CLERK_WEBHOOK_SECRET=

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...

# App
CORS_ORIGINS=http://localhost:3000

# Langfuse tracing (optional — leave empty to disable)
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_BASE_URL=https://us.cloud.langfuse.com
